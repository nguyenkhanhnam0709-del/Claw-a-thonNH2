# ===== Merchant Onboarding Agent - Environment Template =====
# Copy this file to ".env" and fill in real values. Do NOT commit ".env".

# Server
PORT=8080

# LLM (VNG Cloud MaaS - OpenAI compatible)
LLM_API_KEY=your-llm-api-key

# ---- Email gửi qua Gmail / SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password

GMAIL_EMAIL=your-sender@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
