# Production environment for Compliance Agent
# AgentBase may inject these automatically; fill in if running standalone.

# Port the server listens on (AgentBase expects 8080)
PORT=8080

# Gmail credentials for sending approval/rejection emails (optional).
# Leave blank to disable email sending — the agent still runs without it.
# GMAIL_APP_PASSWORD is a Google "App Password", NOT your normal login password.
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
